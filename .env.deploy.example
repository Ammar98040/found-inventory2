# Dokploy/VPS environment file (example)
# Copy to `.env.deploy` on your server (DO NOT commit `.env.deploy`)

DEBUG=False
USE_FILE_LOGGING=False

# Generate a secure key:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me

# Comma-separated
ALLOWED_HOSTS=31.97.197.188,inventory.qrtably.com,localhost,127.0.0.1,0.0.0.0

# SQLite (simple) or PostgreSQL (recommended for production)
USE_SQLITE=True

# If USE_SQLITE=False then set these
DB_NAME=inventory_db
DB_USER=inventory_user
DB_PASSWORD=change-me
DB_HOST=postgres
DB_PORT=5432

# Comma-separated origins (include your https domain)
CSRF_TRUSTED_ORIGINS=https://inventory.qrtably.com,http://inventory.qrtably.com

